# Provider settings.
# Use "openai" for API verification or "ollama" for local verification.
LLM_PROVIDER=ollama
EMBEDDING_PROVIDER=ollama

# Required only when LLM_PROVIDER or EMBEDDING_PROVIDER is "openai".
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI embedding model.
EMBEDDING_MODEL_NAME=text-embedding-ada-002

# Ollama local model settings.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Local Qdrant settings.
QDRANT_PATH=./local_qdrant
COLLECTION_NAME=my_collection
VECTOR_SIZE=768

# Optional OCR settings for scanned PDFs.
# Requires the ocrmypdf CLI and its system dependencies to be installed.
OCR_ENABLED=false
OCR_COMMAND=ocrmypdf
OCR_LANGUAGE=jpn+eng
